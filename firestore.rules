rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DP MEDIA OS - SECURITY RULES ARCHITECTURE
     * 
     * Core Philosophy: 
     * This ruleset implements a robust multi-tenant SaaS security model. Data isolation is 
     * enforced at the company level using a hybrid of path-based and field-based authorization.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/super_admins/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Checks if the user belongs to the company specified in the path or is a platform admin.
    function isMember(companyId) {
      return isSignedIn() && (isSuperAdmin() || getUserData().company_id == companyId);
    }

    function isAdmin(companyId) {
      return isMember(companyId) && (isSuperAdmin() || getUserData().role_id == 'admin');
    }

    // Ensures the document exists and the requester has member-level access.
    function isExistingMember(companyId) {
      return resource != null && isMember(companyId);
    }

    // Validates that the company_id in the document matches the companyId in the path.
    function hasValidCompanyContext(companyId) {
      return request.resource.data.company_id == companyId;
    }

    // Ensures critical relational fields remain unchanged during updates.
    function isCompanyImmutable() {
      return request.resource.data.company_id == resource.data.company_id;
    }

    // --- COLLECTION RULES ---

    match /super_admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isSuperAdmin();
      // Allow the specific bootstrap email to create/update their own administrative marker
      allow create, update: if isSignedIn() && request.auth.token.email == 'arundevv.com@gmail.com' && request.auth.uid == adminId;
      allow delete: if false; 
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin() || getUserData().company_id == resource.data.company_id);
      // Allow users to list others in the same company
      allow list: if isSignedIn() && (isSuperAdmin() || request.query.filters.company_id == getUserData().company_id);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin() || (getUserData().role_id == 'admin' && getUserData().company_id == resource.data.company_id));
      allow delete: if isSuperAdmin();
    }

    match /modules/{moduleId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /subscription_plans/{planId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /companies/{companyId} {
      allow get: if isMember(companyId);
      allow list: if isSuperAdmin();
      allow create: if isSignedIn(); 
      allow update: if isExistingMember(companyId);
      allow delete: if isSuperAdmin();

      // --- TENANT SUBCOLLECTIONS ---

      match /invitations/{invId} {
        allow read, write: if isAdmin(companyId);
      }

      match /roles/{roleId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isExistingMember(companyId) && isCompanyImmutable();
        allow delete: if isExistingMember(companyId);
      }

      match /company_settings/{settingId} {
        allow get, list: if isMember(companyId);
        allow create: if isSignedIn() && hasValidCompanyContext(companyId);
        allow update: if isExistingMember(companyId) && isCompanyImmutable();
        allow delete: if isExistingMember(companyId);
      }

      match /settings_history/{historyId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update, delete: if isSuperAdmin();
      }

      match /activity_logs/{logId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update, delete: if isSuperAdmin();
      }

      match /subscriptions/{subId} {
        allow get: if isMember(companyId);
        allow list: if isMember(companyId);
        allow create, update, delete: if isSuperAdmin();
      }

      // Project Management
      match /projects/{projectId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isExistingMember(companyId) && isCompanyImmutable();
        allow delete: if isExistingMember(companyId);

        match /pre_production_phases/{id} {
          allow read, write: if isMember(companyId);
        }
        match /production_days/{id} {
          allow read, write: if isMember(companyId);
        }
        match /post_production_phases/{id} {
          allow read, write: if isMember(companyId);
        }
        match /project_talents/{id} {
          allow read, write: if isMember(companyId);
        }
        match /budgets/{id} {
          allow read, write: if isMember(companyId);
        }
      }

      // Company-wide Tasks
      match /tasks/{taskId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isExistingMember(companyId) && isCompanyImmutable();
        allow delete: if isExistingMember(companyId);
      }

      // Talent Marketplace
      match /talents/{talentId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isExistingMember(companyId) && isCompanyImmutable();
        allow delete: if isExistingMember(companyId);

        match /talent_metrics/{id} {
          allow read, write: if isMember(companyId);
        }
        match /talent_availability/{id} {
          allow read, write: if isMember(companyId);
        }
        match /talent_reviews/{id} {
          allow read, write: if isMember(companyId);
        }
      }

      match /bookings/{bookingId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isExistingMember(companyId) && isCompanyImmutable();
        allow delete: if isExistingMember(companyId);
      }

      match /contracts/{contractId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isExistingMember(companyId) && isCompanyImmutable();
        allow delete: if isExistingMember(companyId);
      }

      // Sales CRM
      match /leads/{leadId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isExistingMember(companyId) && isCompanyImmutable();
        allow delete: if isExistingMember(companyId);

        match /sales_activities/{id} {
          allow read, write: if isMember(companyId);
        }
      }

      match /proposals/{proposalId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isExistingMember(companyId) && isCompanyImmutable();
        allow delete: if isExistingMember(companyId);
      }

      // Finance & Invoices
      match /invoices/{invoiceId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isExistingMember(companyId) && isCompanyImmutable();
        allow delete: if isExistingMember(companyId);

        match /payments/{id} {
          allow read, write: if isMember(companyId);
        }
      }

      match /company_integrations/{id} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isExistingMember(companyId) && isCompanyImmutable();
        allow delete: if isSuperAdmin();
      }

      match /invoice_sync_logs/{id} {
        allow get, list: if isMember(companyId);
        allow create, update, delete: if isSuperAdmin(); 
      }

      // Market Research
      match /market_research_sessions/{id} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isExistingMember(companyId) && isCompanyImmutable();
        allow delete: if isExistingMember(companyId);

        match /trend_reports/{reportId} {
          allow read, write: if isMember(companyId);
        }
        match /competitor_analysis/{analysisId} {
          allow read, write: if isMember(companyId);
        }
      }
    }
  }
}
