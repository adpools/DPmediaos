
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DP MEDIA OS - SECURITY RULES ARCHITECTURE
     * 
     * Core Philosophy: 
     * Robust multi-tenant SaaS model. Data isolation is enforced at the company level. 
     * Platform-wide Super Admins (identified by email or DB marker) bypass restrictions.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Ultimate authority check for the bootstrap administrator
    function isPlatformAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'arundevv.com@gmail.com' || 
        exists(/databases/$(database)/documents/super_admins/$(request.auth.uid))
      );
    }

    // Safely retrieves user profile data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userProfileExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Checks if the user belongs to the specified company or has platform-wide authority.
    function isMember(companyId) {
      return isSignedIn() && (
        isPlatformAdmin() || 
        (userProfileExists() && getUserData().company_id == companyId)
      );
    }

    // Checks for administrative role within a company or platform-wide authority.
    function isCompanyAdmin(companyId) {
      return isSignedIn() && (
        isPlatformAdmin() || 
        (userProfileExists() && getUserData().company_id == companyId && getUserData().role_id == 'admin')
      );
    }

    // Validates that the data being written belongs to the correct company context.
    function hasValidCompanyContext(companyId) {
      return request.resource.data.company_id == companyId;
    }

    // Ensures company_id field remains unchanged during updates.
    function isCompanyImmutable() {
      return request.resource.data.company_id == resource.data.company_id;
    }

    // --- COLLECTION RULES ---

    match /super_admins/{adminId} {
      // Allow any signed-in user to check if someone is an admin (required for some exists() logic)
      allow get: if isSignedIn();
      // Only platform admins can list all admins
      allow list: if isPlatformAdmin();
      // Allow the bootstrap email to provision its own admin marker
      allow create, update: if isSignedIn() && (request.auth.token.email == 'arundevv.com@gmail.com' || isPlatformAdmin()) && request.auth.uid == adminId;
      // Only existing admins can delete markers (except the bootstrap one)
      allow delete: if isPlatformAdmin() && adminId != 'b0gLru8vzBQjZSOFsiuogZGL6ib2'; 
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        isPlatformAdmin() || 
        (userProfileExists() && getUserData().company_id == get(/databases/$(database)/documents/users/$(userId)).data.company_id)
      );
      // List users if admin or filtered by user's own company
      allow list: if isSignedIn() && (
        isPlatformAdmin() || 
        (userProfileExists() && request.query.filters.company_id == getUserData().company_id)
      );
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        isPlatformAdmin() || 
        (userProfileExists() && isCompanyAdmin(resource.data.company_id))
      );
      allow delete: if isPlatformAdmin();
    }

    match /companies/{companyId} {
      allow get: if isMember(companyId);
      allow list: if isPlatformAdmin();
      allow create: if isSignedIn(); 
      allow update: if isMember(companyId);
      allow delete: if isPlatformAdmin();

      // --- TENANT SUBCOLLECTIONS ---

      match /invitations/{invId} {
        allow read, write: if isCompanyAdmin(companyId);
      }

      match /roles/{roleId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isMember(companyId) && isCompanyImmutable();
        allow delete: if isMember(companyId);
      }

      match /company_settings/{settingId} {
        allow get, list: if isMember(companyId);
        allow create: if isSignedIn() && hasValidCompanyContext(companyId);
        allow update: if isMember(companyId) && isCompanyImmutable();
        allow delete: if isMember(companyId);
      }

      match /projects/{projectId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isMember(companyId) && isCompanyImmutable();
        allow delete: if isMember(companyId);

        match /{allSubcollections=**} {
          allow read, write: if isMember(companyId);
        }
      }

      match /tasks/{taskId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isMember(companyId) && isCompanyImmutable();
        allow delete: if isMember(companyId);
      }

      match /talents/{talentId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isMember(companyId) && isCompanyImmutable();
        allow delete: if isMember(companyId);

        match /{allSubcollections=**} {
          allow read, write: if isMember(companyId);
        }
      }

      match /leads/{leadId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isMember(companyId) && isCompanyImmutable();
        allow delete: if isMember(companyId);

        match /{allSubcollections=**} {
          allow read, write: if isMember(companyId);
        }
      }

      match /proposals/{proposalId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isMember(companyId) && isCompanyImmutable();
        allow delete: if isMember(companyId);
      }

      match /invoices/{invoiceId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isMember(companyId) && isCompanyImmutable();
        allow delete: if isMember(companyId);

        match /{allSubcollections=**} {
          allow read, write: if isMember(companyId);
        }
      }

      match /market_research_sessions/{id} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isMember(companyId) && isCompanyImmutable();
        allow delete: if isMember(companyId);

        match /{allSubcollections=**} {
          allow read, write: if isMember(companyId);
        }
      }
    }
  }
}
