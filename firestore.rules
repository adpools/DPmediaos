
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DP MEDIA OS - SECURITY RULES ARCHITECTURE
     * 
     * Core Philosophy: 
     * This ruleset implements a robust multi-tenant SaaS security model. Data isolation is 
     * enforced at the company level using a hybrid of path-based and field-based authorization.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      // Prioritize email check to avoid evaluation loops during bootstrap
      return isSignedIn() && (request.auth.token.email == 'arundevv.com@gmail.com' || exists(/databases/$(database)/documents/super_admins/$(request.auth.uid)));
    }

    // Safely retrieves user data only if the document exists
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    // Checks if the user belongs to the company specified in the path or is a platform admin.
    function isMember(companyId) {
      if (!isSignedIn()) return false;
      if (isSuperAdmin()) return true;
      let userData = getUserData();
      return userData != null && userData.company_id == companyId;
    }

    function isAdmin(companyId) {
      if (!isSignedIn()) return false;
      if (isSuperAdmin()) return true;
      let userData = getUserData();
      return userData != null && userData.company_id == companyId && userData.role_id == 'admin';
    }

    // Validates that the company_id in the document matches the companyId in the path.
    function hasValidCompanyContext(companyId) {
      return request.resource.data.company_id == companyId;
    }

    // Ensures critical relational fields remain unchanged during updates.
    function isCompanyImmutable() {
      return request.resource.data.company_id == resource.data.company_id;
    }

    // --- COLLECTION RULES ---

    match /super_admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isSuperAdmin();
      // Allow the specific bootstrap email to create/update their own administrative marker
      allow create, update: if isSignedIn() && (request.auth.token.email == 'arundevv.com@gmail.com' || isSuperAdmin()) && request.auth.uid == adminId;
      allow delete: if isSuperAdmin() && request.auth.token.email != 'arundevv.com@gmail.com'; 
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin() || (getUserData() != null && getUserData().company_id == get(/databases/$(database)/documents/users/$(userId)).data.company_id));
      allow list: if isSignedIn() && (isSuperAdmin() || (getUserData() != null && request.query.filters.company_id == getUserData().company_id));
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin() || (isAdmin(resource.data.company_id)));
      allow delete: if isSuperAdmin();
    }

    match /modules/{moduleId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /subscription_plans/{planId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /companies/{companyId} {
      allow get: if isMember(companyId);
      allow list: if isSuperAdmin();
      allow create: if isSignedIn(); 
      allow update: if isMember(companyId);
      allow delete: if isSuperAdmin();

      // --- TENANT SUBCOLLECTIONS ---

      match /invitations/{invId} {
        allow read, write: if isAdmin(companyId);
      }

      match /roles/{roleId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isMember(companyId) && isCompanyImmutable();
        allow delete: if isMember(companyId);
      }

      match /company_settings/{settingId} {
        allow get, list: if isMember(companyId);
        allow create: if isSignedIn() && hasValidCompanyContext(companyId);
        allow update: if isMember(companyId) && isCompanyImmutable();
        allow delete: if isMember(companyId);
      }

      match /projects/{projectId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isMember(companyId) && isCompanyImmutable();
        allow delete: if isMember(companyId);

        match /{allSubcollections=**} {
          allow read, write: if isMember(companyId);
        }
      }

      match /tasks/{taskId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isMember(companyId) && isCompanyImmutable();
        allow delete: if isMember(companyId);
      }

      match /talents/{talentId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isMember(companyId) && isCompanyImmutable();
        allow delete: if isMember(companyId);

        match /{allSubcollections=**} {
          allow read, write: if isMember(companyId);
        }
      }

      match /leads/{leadId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isMember(companyId) && isCompanyImmutable();
        allow delete: if isMember(companyId);

        match /{allSubcollections=**} {
          allow read, write: if isMember(companyId);
        }
      }

      match /proposals/{proposalId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isMember(companyId) && isCompanyImmutable();
        allow delete: if isMember(companyId);
      }

      match /invoices/{invoiceId} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isMember(companyId) && isCompanyImmutable();
        allow delete: if isMember(companyId);

        match /{allSubcollections=**} {
          allow read, write: if isMember(companyId);
        }
      }

      match /market_research_sessions/{id} {
        allow get, list: if isMember(companyId);
        allow create: if isMember(companyId) && hasValidCompanyContext(companyId);
        allow update: if isMember(companyId) && isCompanyImmutable();
        allow delete: if isMember(companyId);

        match /{allSubcollections=**} {
          allow read, write: if isMember(companyId);
        }
      }
    }
  }
}
