{
  "entities": {
    "Company": {
      "title": "Company",
      "type": "object",
      "description": "Represents a single company (tenant) within the multi-tenant SaaS platform.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "onboardingStatus": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "onboardingStatus", "createdAt"]
    },
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user account within a specific company.",
      "properties": {
        "id": { "type": "string" },
        "company_id": { "type": "string" },
        "role_id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "company_id", "role_id", "email", "fullName", "status", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "type": "object",
      "description": "Represents a media production workspace.",
      "properties": {
        "id": { "type": "string" },
        "company_id": { "type": "string" },
        "project_name": { "type": "string" },
        "client_name": { "type": "string" },
        "status": { "type": "string" },
        "progress": { "type": "number" },
        "budget": { "type": "number" },
        "deadline": { "type": "string" },
        "color": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "description": "Represents a financial billing record.",
      "properties": {
        "id": { "type": "string" },
        "company_id": { "type": "string" },
        "client_name": { "type": "string" },
        "invoice_number": { "type": "string" },
        "total": { "type": "number" },
        "payment_status": { "type": "string" },
        "due_date": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "Lead": {
      "title": "Lead",
      "type": "object",
      "description": "Represents a sales opportunity or client company.",
      "properties": {
        "id": { "type": "string" },
        "company_id": { "type": "string" },
        "company_name": { "type": "string" },
        "contact_person": { "type": "string" },
        "email": { "type": "string" },
        "industry": { "type": "string" },
        "stage": { "type": "string" },
        "deal_value": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "super_admins/{userId}": {
      "schema": {
        "type": "object",
        "properties": {
          "uid": { "type": "string" },
          "email": { "type": "string" },
          "granted_at": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Platform-wide super administrators."
    },
    "users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles and workspace affiliation."
    },
    "companies/{companyId}": {
      "schema": { "$ref": "#/backend/entities/Company" },
      "description": "Multi-tenant company roots."
    },
    "companies/{companyId}/projects/{projectId}": {
      "schema": { "$ref": "#/backend/entities/Project" },
      "description": "Production workspaces."
    },
    "companies/{companyId}/invoices/{invoiceId}": {
      "schema": { "$ref": "#/backend/entities/Invoice" },
      "description": "Billing records."
    },
    "companies/{companyId}/leads/{leadId}": {
      "schema": { "$ref": "#/backend/entities/Lead" },
      "description": "CRM opportunities and clients."
    },
    "companies/{companyId}/invitations/{invId}": {
      "schema": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "role_id": { "type": "string" },
          "status": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Team invitations."
    }
  }
}